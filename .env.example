# Copy to .env.local for local development.
#
# Public API base URL (must include `/api`). Leave empty to use the Next.js `/api-proxy` rewrite in dev.
NEXT_PUBLIC_API_URL=
#
# Default (recommended): do NOT set NEXT_PUBLIC_API_URL — Next.js proxies /api-proxy → Laravel (:8000).
# Override only if you want the browser to talk to Laravel directly:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
#
# Production (Vercel): set NEXT_PUBLIC_API_URL to your public API base URL (must include /api).
#
# Local `npm run start` (production build): rewrites for /api-proxy are disabled — set:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
# so the browser can reach Laravel on :8000.
